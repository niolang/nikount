[Unit]
Description=Nikount Flask application
After=network.target

[Service]
Type=simple
User=nikount
Group=www-data
WorkingDirectory=/opt/nikount
EnvironmentFile=/etc/nikount.env
ExecStart=/opt/nikount/venv/bin/python /opt/nikount/app.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
